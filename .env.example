# Magic Master — переменные окружения
# Скопируйте в .env и заполните:
#   cp .env.example .env

# ─── Безопасность ─────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО: длинная случайная строка (минимум 32 символа)
MAGIC_MASTER_JWT_SECRET=change-me-use-a-long-random-32char-string

# ─── Администратор ────────────────────────────────────────────────────────────
# При первом запуске создастся администратор с этими данными
MAGIC_MASTER_ADMIN_EMAIL=admin@your-domain.com
MAGIC_MASTER_ADMIN_PASSWORD=change-me-strong-admin-password

# ─── Сервер ───────────────────────────────────────────────────────────────────
MAGIC_MASTER_HOST=0.0.0.0
MAGIC_MASTER_PORT=8000
# Максимальный размер загружаемого файла (МБ)
MAGIC_MASTER_MAX_UPLOAD_MB=200
# Режим отладки (убрать или оставить 0 в production)
MAGIC_MASTER_DEBUG=0
# Email-верификация: если 1 — новые пользователи должны подтвердить email
# По умолчанию 0 (отключено) для совместимости с существующими аккаунтами
MAGIC_MASTER_REQUIRE_EMAIL_VERIFY=0
# P46: глобальный rate limit — запросов в минуту с одного IP для API (0 = отключить)
MAGIC_MASTER_GLOBAL_RATE_LIMIT=300
# P56: CORS — разрешённые origins через запятую; пусто = все (*). В production укажите свой домен, например:
# MAGIC_MASTER_CORS_ORIGINS=https://magicmaster.pro,https://www.magicmaster.pro
MAGIC_MASTER_CORS_ORIGINS=
# P51: Telegram-уведомления для администратора
# Создайте бота: @BotFather → /newbot → получите токен
# Узнайте chat_id: напишите боту и вызовите https://api.telegram.org/bot<TOKEN>/getUpdates
MAGIC_MASTER_TELEGRAM_BOT_TOKEN=
MAGIC_MASTER_TELEGRAM_ADMIN_CHAT_ID=
# Секрет webhook бота уведомлений: POST .../bot/notify/webhook (как у USER_BOT_WEBHOOK_SECRET)
# MAGIC_MASTER_TELEGRAM_BOT_WEBHOOK_SECRET=
# Ссылка на клиентский бот (кнопки меню в уведомительном боте)
# MAGIC_MASTER_USER_BOT_TELEGRAM_URL=https://t.me/magicmasterpro_user_bot
# Мониторинг: алерты в TELEGRAM_ADMIN_CHAT_ID (health, очередь задач, аномалии CPU/RAM/диск)
# MAGIC_MASTER_ALERT_MONITORING_ENABLED=1
# MAGIC_MASTER_ALERT_QUEUE_THRESHOLD=25
# MAGIC_MASTER_ALERT_THROTTLE_MINUTES=60
# MAGIC_MASTER_ANOMALY_CHECK_INTERVAL=60
# MAGIC_MASTER_ANOMALY_CPU_THRESHOLD=85
# MAGIC_MASTER_ANOMALY_RAM_THRESHOLD=85
# MAGIC_MASTER_ANOMALY_DISK_THRESHOLD=85
# MAGIC_MASTER_ANOMALY_ERROR_RATE_THRESHOLD=35
# MAGIC_MASTER_ANOMALY_RSS_MAX_MB=8192
# MAGIC_MASTER_ANOMALY_MIN_JOBS_FOR_ERROR_RATE=8

# Telegram user bot (клиентский бот в DM; админ-алерты — только TELEGRAM_* выше)
# @BotFather → новый бот → токен. Webhook: домен + Nginx location /bot/
# Секрет: openssl rand -hex 16
MAGIC_MASTER_USER_BOT_TOKEN=
MAGIC_MASTER_USER_BOT_WEBHOOK_SECRET=
# Канал для новостей (username @PROmagicmaster или id -100...)
MAGIC_MASTER_USER_BOT_CHANNEL_ID=@PROmagicmaster
# Публичный URL сайта (для webhook и ссылок в боте)
MAGIC_MASTER_PUBLIC_BASE_URL=https://magicmaster.pro

# ─── SMTP (для email-уведомлений) ─────────────────────────────────────────────
# Gmail: smtp.gmail.com, порт 587, используйте App Password
# Yandex: smtp.yandex.ru, порт 465 (SSL) или 587 (TLS)
MAGIC_MASTER_SMTP_HOST=smtp.gmail.com
MAGIC_MASTER_SMTP_PORT=587
MAGIC_MASTER_SMTP_USER=your-email@gmail.com
MAGIC_MASTER_SMTP_PASSWORD=your-app-password
MAGIC_MASTER_SMTP_FROM=Magic Master <noreply@your-domain.com>
MAGIC_MASTER_SMTP_USE_TLS=true

# ─── YooKassa (платёжная система) ─────────────────────────────────────────────
# Получите в личном кабинете: https://yookassa.ru/my/shop-settings/payments
MAGIC_MASTER_YOOKASSA_SHOP_ID=
MAGIC_MASTER_YOOKASSA_SECRET_KEY=
MAGIC_MASTER_YOOKASSA_RETURN_URL=https://magicmaster.pro/pricing?payment=success
# P56: webhook — опциональный whitelist IP (через запятую). Если задан, уведомления принимаются только с этих IP.
# Уточните актуальные IP в документации YooKassa или у поддержки.
# MAGIC_MASTER_YOOKASSA_WEBHOOK_IP_WHITELIST=1.2.3.4,5.6.7.8
MAGIC_MASTER_YOOKASSA_WEBHOOK_IP_WHITELIST=

# ─── AI (OpenAI / DeepSeek) ───────────────────────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
MAGIC_MASTER_OPENAI_API_KEY=
# DeepSeek (рекомендуется, дешевле): https://platform.deepseek.com
MAGIC_MASTER_DEEPSEEK_API_KEY=
# DeepSeek: базовый URL и модель (по умолчанию deepseek-chat)
MAGIC_MASTER_DEEPSEEK_BASE_URL=https://api.deepseek.com
MAGIC_MASTER_DEEPSEEK_MODEL=deepseek-chat
# Какой провайдер использовать: openai | deepseek
MAGIC_MASTER_AI_BACKEND=deepseek
