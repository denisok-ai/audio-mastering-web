# Magic Master — профиль для выделенного сервера
# 6 vCPU / 12 GB RAM / 160 GB SSD (например RU vm.medium VPS)
# Использование: скопируйте нужные строки в .env поверх дефолтов из .env.example

# ─── Лимиты под железо (12 GB RAM, 6 vCPU) ─────────────────────────────────────
# Максимальный размер загружаемого файла (МБ); на 160 GB SSD можно 200–300
MAGIC_MASTER_MAX_UPLOAD_MB=250
# Одновременных задач мастеринга: Pro/Studio и Free (больше ядер — больше слотов)
MAGIC_MASTER_SEMAPHORE_PRIORITY=4
MAGIC_MASTER_SEMAPHORE_NORMAL=2
# Максимум записей в очереди задач в памяти
MAGIC_MASTER_JOBS_MAX_ENTRIES=300
# Время хранения завершённых задач (секунды), чтобы не терять результаты при нагрузке
MAGIC_MASTER_JOBS_DONE_TTL_SECONDS=7200
# Глобальный rate limit — запросов в минуту с одного IP (на выделенном сервере можно выше)
MAGIC_MASTER_GLOBAL_RATE_LIMIT=600

# Прод-домен (см. doc/MAGICMASTER_PRO.md)
MAGIC_MASTER_CORS_ORIGINS=https://magicmaster.pro,https://www.magicmaster.pro
# MAGIC_MASTER_YOOKASSA_RETURN_URL=https://magicmaster.pro/pricing?payment=success

# Остальные переменные (JWT, ADMIN_*, SMTP, YooKassa и т.д.) берите из .env.example
