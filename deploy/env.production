# Magic Master — production .env
# Сервер: 6 vCPU / 12 GB RAM / 160 GB SSD / Ubuntu 22.04
# Домен: magicmaster.pro

# ─── Безопасность ─────────────────────────────────────────────────────────────
MAGIC_MASTER_JWT_SECRET=CHANGE_ME_GENERATE_WITH_python3_-c_import_secrets_print_secrets.token_urlsafe_48

# ─── Режим (production = без debug) ──────────────────────────────────────────
MAGIC_MASTER_DEBUG=0

# ─── CORS ─────────────────────────────────────────────────────────────────────
MAGIC_MASTER_CORS_ORIGINS=https://magicmaster.pro,https://www.magicmaster.pro

# ─── Лимиты под железо (12 GB RAM, 6 vCPU) ──────────────────────────────────
MAGIC_MASTER_MAX_UPLOAD_MB=250
MAGIC_MASTER_SEMAPHORE_PRIORITY=4
MAGIC_MASTER_SEMAPHORE_NORMAL=2
MAGIC_MASTER_JOBS_MAX_ENTRIES=300
MAGIC_MASTER_JOBS_DONE_TTL_SECONDS=7200
MAGIC_MASTER_GLOBAL_RATE_LIMIT=600

# ─── Сервер ───────────────────────────────────────────────────────────────────
MAGIC_MASTER_HOST=0.0.0.0
MAGIC_MASTER_PORT=8000

# ─── YooKassa ─────────────────────────────────────────────────────────────────
MAGIC_MASTER_YOOKASSA_RETURN_URL=https://magicmaster.pro/pricing?payment=success

# ─── Алерты админу (Telegram TELEGRAM_*): при 1 — фоновый мониторинг аномалий + health
# MAGIC_MASTER_ALERT_MONITORING_ENABLED=1
# MAGIC_MASTER_ALERT_QUEUE_THRESHOLD=25

# ─── AI (DeepSeek — рекомендуется для консультанта) ──────────────────────────
MAGIC_MASTER_AI_BACKEND=deepseek
# Ключ настраивается через админ-панель (Settings → deepseek_api_key)
# MAGIC_MASTER_DEEPSEEK_BASE_URL=https://api.deepseek.com
# MAGIC_MASTER_DEEPSEEK_MODEL=deepseek-chat

# ─── Telegram user bot (клиентский; см. doc/TELEGRAM_USER_BOT.md) ─────────────
# MAGIC_MASTER_USER_BOT_TOKEN=
# MAGIC_MASTER_USER_BOT_WEBHOOK_SECRET=
# MAGIC_MASTER_USER_BOT_CHANNEL_ID=@PROmagicmaster
# MAGIC_MASTER_PUBLIC_BASE_URL=https://magicmaster.pro
